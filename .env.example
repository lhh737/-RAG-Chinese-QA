# ============================================================
# RAG 中文文档问答系统 - 环境配置模板
# 复制为 .env 并填入真实值
# ============================================================

# ---------- 阿里云 DashScope API ----------
DASHSCOPE_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- LLM 推理模型 ----------
LLM_MODEL_ID=qwen-max

# ---------- 嵌入模型 ----------
# 模式: api (DashScope) 或 local (BGE)
EMBED_MODE=api
EMBED_API_MODEL=text-embedding-async-v2
# 本地模式下的模型路径
# EMBED_LOCAL_MODEL=models/bge-m3

# ---------- 重排序模型 ----------
# 模式: api (DashScope) 或 local (BGE)
RERANK_MODE=api
RERANK_API_MODEL=gte-rerank-v2
# 本地模式下的模型路径
# RERANK_LOCAL_MODEL=models/bge-reranker-base

# ---------- FAISS 向量库 ----------
FAISS_PERSIST_DIR=faiss_db
DATA_DIR=data
UPLOAD_DIR=data/uploads

# ---------- 分块参数 ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ---------- 检索参数 ----------
RETRIEVAL_K=5
